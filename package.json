{
  "name": "a11y-dev-helper",
  "displayName": "A11y Dev Helper",
  "description": "Detecta problemas comuns de acessibilidade em HTML, JSX e TSX com 26 regras WCAG 2.1.",
  "version": "0.1.0",
  "publisher": "seu-publisher-id",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/seu-usuario/a11y-dev-helper"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Linters",
    "Education"
  ],
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "html",
    "jsx"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "A11y Dev Helper",
      "properties": {
        "a11yDevHelper.rules": {
          "type": "object",
          "description": "Habilita ou desabilita regras individuais de acessibilidade.",
          "default": {
            "img-missing-alt": true,
            "html-missing-lang": true,
            "link-generic-text": true,
            "link-missing-href": true,
            "link-empty": true,
            "button-missing-name": true,
            "button-emoji-only": true,
            "button-only-svg": true,
            "div-span-onclick": true,
            "clickable-no-keyboard-support": true,
            "autofocus": true,
            "input-missing-label": true,
            "input-placeholder-no-label": true,
            "select-missing-label": true,
            "fieldset-missing-legend": true,
            "label-missing-for-id": true,
            "heading-order": true,
            "iframe-missing-title": true,
            "table-missing-caption": true,
            "video-missing-track": true,
            "tabindex-positive": true,
            "aria-invalid-role": true,
            "aria-referenced-id": true,
            "duplicate-id": true,
            "color-contrast": true,
            "small-font-size": true
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "parse5": "^7.2.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
